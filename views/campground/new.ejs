<% layout("layouts/boilerplate") %>

<div class="row">
  <h1 class="text-center">キャンプ場の新規登録</h1>
  <div class="offset-3 col-6">
    <form action="/campgrounds" method="post">
      <div class="mb-3">
        <label for="title" class="form-label">キャンプ場名</label>
        <input
          class="form-control"
          type="text"
          id="title"
          name="campground[title]"
          placeholder="キャンプ場名"
        />
      </div>
      <div class="mb-3">
        <label for="location" class="form-label">所在地</label>
        <input
          class="form-control"
          type="text"
          id="location"
          name="campground[location]"
          placeholder="所在地"
        />
      </div>
      <div class="mb-3">
        <label for="price" class="form-label">価格</label>
        <div class="input-group">
          <span class="input-group-text" id="price-en">¥</span>
          <input
            type="Number"
            class="form-control"
            id="price"
            placeholder="価格"
            name="campground[price]"
            aria-describedby="price-en"
          />
        </div>
      </div>

      <div class="mb-3">
        <label for="imageUrl" class="form-label">画像URL</label>
        <input
          class="form-control"
          type="text"
          id="imageUrl"
          name="campground[imageUrl]"
          placeholder="画像URL"
        />
      </div>
      <div class="mb-3">
        <label for="description" class="form-label">キャンプ場の説明</label>
        <textarea
          class="form-control"
          type="text"
          id="description"
          name="campground[description]"
          placeholder=""
        ></textarea>
      </div>
      <button class="btn btn-success">登録</button>
    </form>
  </div>
</div>
